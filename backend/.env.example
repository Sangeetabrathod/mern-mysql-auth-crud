# Backend Environment Variables
# Copy to .env and fill values

# Database (MySQL - update with your credentials)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=mern_auth_db

# JWT (change in production!)
JWT_SECRET=campuspe_jwt_secret_2024_change_this_very_important_do_not_share

# Server
PORT=5000
NODE_ENV=development

# Email (optional - for forgot-password, enable in authController.js)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password

# Production (optional)
# SESSION_SECRET=another_secret_key
